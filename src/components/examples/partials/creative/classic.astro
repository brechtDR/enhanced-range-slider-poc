---
import ExampleSection from "../../ExampleSection.astro";
import ExampleCodeBlock from "../../ExampleCodeBlock.astro";
import CodeSnippet from "../../CodeSnippet.astro";
---

<ExampleSection id="classic" eyebrow="Creative styling" title="Classic OS look">
    <Fragment slot="description">
        Heavy custom styling on all parts to recreate a classic Win-style slider, with anchored tooltips.
    </Fragment>
    <div slot="demo" style="position: relative">
        <style is:global>
            #classic-range {
                --track-height: 4px;
                --thumb-size: 24px;
            }
            #classic-range::part(slider-track) {
                background: #444;
                border: 1px solid #111;
                border-radius: 0;
                box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.5);
            }
            #classic-range::part(slider-segment-2) {
                background: #3b82f6;
            }
            #classic-range::part(slider-thumb) {
                anchor-name: var(--anchor-name);
                background: linear-gradient(to bottom, #f9fafb, #d1d5db);
                border: 1px solid #6b7280;
                border-radius: 3px;
                width: 14px;
                height: 24px;
                box-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
            }
            #classic-range::part(slider-thumb-1) {
                --anchor-name: --classic-thumb-1;
            }
            #classic-range::part(slider-thumb-2) {
                --anchor-name: --classic-thumb-2;
            }

            .classic-tooltip {
                position: absolute;
                position-anchor: var(--anchor-name);
                position-area: top;
                translate: -20% -60%;
                background: #222;
                color: white;
                padding: 2px 8px;
                border-radius: 3px;
                border: 1px solid #555;
                font-size: 0.875rem;
                font-weight: 600;
                pointer-events: none;
            }
            #classic-tooltip-1 {
                --anchor-name: --classic-thumb-1;
            }
            #classic-tooltip-2 {
                --anchor-name: --classic-thumb-2;
            }
        </style>
        <range-group id="classic-range" min="0" max="100">
            <legend slot="legend" class="visually-hidden">Classic look</legend>
            <label class="visually-hidden">
                Classic Handle 1
                <input type="range" name="classic-1" value="20" />
            </label>
            <label class="visually-hidden">
                Classic Handle 2
                <input type="range" name="classic-2" value="80" />
            </label>
        </range-group>
        <div id="classic-tooltip-1" class="classic-tooltip" aria-hidden="true">20</div>
        <div id="classic-tooltip-2" class="classic-tooltip" aria-hidden="true">80</div>
    </div>
    <ExampleCodeBlock slot="code">
        <CodeSnippet
            lang="html"
            code={`
<rangegroup id="classic-range" min="0" max="100">
  <legend>Classic look</legend>
  <label>Classic Handle 1 <input type="range" value="20"></label>
  <label>Classic Handle 2 <input type="range" value="80"></label>
</rangegroup>
<div id="classic-tooltip-1" class="classic-tooltip">20</div>
<div id="classic-tooltip-2" class="classic-tooltip">80</div>
`}
        />
        <CodeSnippet
            lang="css"
            code={`
/* recessed track with a bevelled fill */
rangegroup::slider-track {
  background: #444;
  border: 1px solid #111;
  border-radius: 0;
  box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.5);
}
rangegroup::slider-segment(2) { background: #3b82f6; }

/* tall rectangular thumbs with a grey-to-light gradient */
rangegroup::slider-thumb(*) {
  width: 14px;
  height: 24px;
  background: linear-gradient(to bottom, #f9fafb, #d1d5db);
  border: 1px solid #6b7280;
  border-radius: 3px;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
}
rangegroup::slider-thumb(1) { anchor-name: --classic-thumb-1; }
rangegroup::slider-thumb(2) { anchor-name: --classic-thumb-2; }

/* black tooltips parked above each thumb */
.classic-tooltip {
  position: absolute;
  position-area: top;
  translate: -20% -60%;
  background: #222;
  color: white;
  padding: 2px 8px;
  border: 1px solid #555;
  border-radius: 3px;
  font-weight: 600;
  pointer-events: none;
}
#classic-tooltip-1 { position-anchor: --classic-thumb-1; }
#classic-tooltip-2 { position-anchor: --classic-thumb-2; }
`}
        />
        <CodeSnippet
            lang="javascript"
            code={`
const rg = document.querySelector("#classic-range");
const t1 = document.querySelector("#classic-tooltip-1");
const t2 = document.querySelector("#classic-tooltip-2");

rg.addEventListener("input", () => {
  const [a, b] = rg.values;
  t1.textContent = Math.round(a);
  t2.textContent = Math.round(b);
});
`}
        />
    </ExampleCodeBlock>
    <script is:inline slot="runtime">
        (() => {
            const init = () => {
                const rg = document.querySelector("#classic-range");
                const t1 = document.querySelector("#classic-tooltip-1");
                const t2 = document.querySelector("#classic-tooltip-2");

                rg.addEventListener("input", () => {
                    const [a, b] = rg.values;
                    t1.textContent = Math.round(a);
                    t2.textContent = Math.round(b);
                });
            };

            const run = () => {
                if (typeof customElements?.whenDefined === "function") {
                    customElements
                        .whenDefined("range-group")
                        .then(init)
                        .catch(() => init());
                    return;
                }
                init();
            };

            if (document.readyState === "loading") {
                document.addEventListener("DOMContentLoaded", run, { once: true });
            } else {
                run();
            }
        })();
    </script>
</ExampleSection>
