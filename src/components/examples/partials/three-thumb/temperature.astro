---
import ExampleSection from "../../ExampleSection.astro";
import ExampleCodeBlock from "../../ExampleCodeBlock.astro";
import CodeSnippet from "../../CodeSnippet.astro";
---

<ExampleSection id="temperature" eyebrow="Three-plus thumb patterns" title="Multi-handle temperature">
    <Fragment slot="description">
        Three handles set boundaries for cold / mild / warm / hot zones, each segment rendered in its own colour and
        each thumb with a matching glow.
    </Fragment>
    <div slot="demo" class="temp-card">
        <style is:global>
            .temp-card {
                --temp-cold: oklch(65% 0.25 260);
                --temp-mild: oklch(70% 0.2 180);
                --temp-warm: oklch(80% 0.2 90);
                --temp-hot: oklch(65% 0.25 25);
            }
            .temp-stage {
                position: relative;
                padding-top: 60px;
                padding-inline: 36px;
            }
            #temp-range {
                --thumb-size: 22px;
                --track-height: 8px;
            }
            .temp-icon {
                position: absolute;
                bottom: 12px;
                width: 22px;
                height: 22px;
                pointer-events: none;
            }
            .temp-icon-snow {
                left: 4px;
                color: var(--temp-cold);
            }
            .temp-icon-flame {
                right: 4px;
                color: var(--temp-hot);
            }
            #temp-range::part(slider-segment-1) {
                background-color: var(--temp-cold);
                anchor-name: --temp-seg-1;
            }
            #temp-range::part(slider-segment-2) {
                background-color: var(--temp-mild);
                anchor-name: --temp-seg-2;
            }
            #temp-range::part(slider-segment-3) {
                background-color: var(--temp-warm);
                anchor-name: --temp-seg-3;
            }
            #temp-range::part(slider-segment-4) {
                background-color: var(--temp-hot);
                anchor-name: --temp-seg-4;
            }
            #temp-range::part(slider-thumb) {
                box-shadow:
                    inset 0 0 0 2px white,
                    0 2px 8px rgba(0, 0, 0, 0.18);
                background-color: transparent;
                background-repeat: no-repeat;
            }
            #temp-range::part(slider-thumb-1) {
                --slider-thumb-color: var(--temp-cold);
                --slider-thumb-ring-color: color-mix(in oklab, var(--temp-cold) 40%, white);
                background-image: conic-gradient(
                    from 180deg,
                    var(--temp-cold) 0deg 180deg,
                    var(--temp-mild) 180deg 360deg
                );
            }
            #temp-range::part(slider-thumb-2) {
                --slider-thumb-color: var(--temp-mild);
                --slider-thumb-ring-color: color-mix(in oklab, var(--temp-mild) 40%, white);
                background-image: conic-gradient(
                    from 180deg,
                    var(--temp-mild) 0deg 180deg,
                    var(--temp-warm) 180deg 360deg
                );
            }
            #temp-range::part(slider-thumb-3) {
                --slider-thumb-color: var(--temp-warm);
                --slider-thumb-ring-color: color-mix(in oklab, var(--temp-warm) 40%, white);
                background-image: conic-gradient(
                    from 180deg,
                    var(--temp-warm) 0deg 180deg,
                    var(--temp-hot) 180deg 360deg
                );
            }
            .temp-zone {
                position: absolute;
                font-size: 0.72rem;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                font-weight: 700;
                color: var(--text-strong);
                background: white;
                border: 1px solid var(--border);
                padding: 3px 8px;
                border-radius: 999px;
                pointer-events: none;
                white-space: nowrap;
                bottom: anchor(top);
                left: anchor(center);
                translate: -50% -10px;
                box-shadow: 0 2px 6px rgba(0, 0, 0, 0.06);
            }
            .temp-zone-1 {
                position-anchor: --temp-seg-1;
                color: var(--temp-cold);
                border-color: color-mix(in oklab, var(--temp-cold) 35%, var(--border));
            }
            .temp-zone-2 {
                position-anchor: --temp-seg-2;
                color: oklch(45% 0.18 180);
                border-color: color-mix(in oklab, var(--temp-mild) 35%, var(--border));
            }
            .temp-zone-3 {
                position-anchor: --temp-seg-3;
                color: oklch(55% 0.18 75);
                border-color: color-mix(in oklab, var(--temp-warm) 35%, var(--border));
            }
            .temp-zone-4 {
                position-anchor: --temp-seg-4;
                color: var(--temp-hot);
                border-color: color-mix(in oklab, var(--temp-hot) 35%, var(--border));
            }
            .temp-readout {
                margin-top: 1.5rem;
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                gap: 10px;
            }
            .temp-readout-cell {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: 10px;
                padding: 10px 12px;
                display: grid;
                gap: 4px;
            }
            .temp-readout-cell::before {
                content: "";
                width: 18px;
                height: 4px;
                border-radius: 999px;
                background: var(--temp-cell-color, var(--temp-cold));
            }
            .temp-readout-cell[data-zone="cold"] {
                --temp-cell-color: var(--temp-cold);
            }
            .temp-readout-cell[data-zone="mild"] {
                --temp-cell-color: var(--temp-mild);
            }
            .temp-readout-cell[data-zone="warm"] {
                --temp-cell-color: var(--temp-warm);
            }
            .temp-readout-cell[data-zone="hot"] {
                --temp-cell-color: var(--temp-hot);
            }
            .temp-readout-label {
                font-size: 0.68rem;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: var(--text-soft);
                font-weight: 700;
            }
            .temp-readout-value {
                font-family: "Source Code Pro", "JetBrains Mono", monospace;
                font-size: 0.88rem;
                color: var(--text-strong);
                font-weight: 600;
            }
        </style>
        <div class="temp-stage">
            <svg
                class="temp-icon temp-icon-snow"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                aria-hidden="true"
            >
                <line x1="12" y1="3" x2="12" y2="21"></line>
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="5.6" y1="5.6" x2="18.4" y2="18.4"></line>
                <line x1="18.4" y1="5.6" x2="5.6" y2="18.4"></line>
                <path d="M9 5l3 3 3-3M9 19l3-3 3 3M5 9l3 3-3 3M19 9l-3 3 3 3"></path>
            </svg>
            <svg class="temp-icon temp-icon-flame" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path
                    d="M12 2c.5 4-2.5 5-2.5 8.5C9.5 13 11 14 12 14s2.5-1 2.5-3.5C14.5 7 11.5 6 12 2zM5.5 13c0 4 2.9 7 6.5 7s6.5-3 6.5-7c0-2.4-1.4-3.5-2.6-4.5.4 2.5-1.2 3.5-2.4 3.5-1.6 0-2.5-1-2.5-3 0-1.6.8-3 1.8-4-3.2.3-7.3 3-7.3 8z"
                ></path>
            </svg>
            <range-group id="temp-range" min="-100" max="100">
                <legend slot="legend" class="visually-hidden">Multi-handle temperature</legend>
                <label class="visually-hidden">
                    Cold bound
                    <input type="range" name="temp-cold" value="-50" />
                </label>
                <label class="visually-hidden">
                    Mild bound
                    <input type="range" name="temp-mild" value="0" />
                </label>
                <label class="visually-hidden">
                    Hot bound
                    <input type="range" name="temp-hot" value="50" />
                </label>
            </range-group>
            <div class="temp-zone temp-zone-1" aria-hidden="true">Cold</div>
            <div class="temp-zone temp-zone-2" aria-hidden="true">Mild</div>
            <div class="temp-zone temp-zone-3" aria-hidden="true">Warm</div>
            <div class="temp-zone temp-zone-4" aria-hidden="true">Hot</div>
        </div>
        <div class="temp-readout">
            <div class="temp-readout-cell" data-zone="cold">
                <span class="temp-readout-label">Cold</span>
                <span class="temp-readout-value" id="temp-readout-cold">-100° to -50°</span>
            </div>
            <div class="temp-readout-cell" data-zone="mild">
                <span class="temp-readout-label">Mild</span>
                <span class="temp-readout-value" id="temp-readout-mild">-50° to 0°</span>
            </div>
            <div class="temp-readout-cell" data-zone="warm">
                <span class="temp-readout-label">Warm</span>
                <span class="temp-readout-value" id="temp-readout-warm">0° to 50°</span>
            </div>
            <div class="temp-readout-cell" data-zone="hot">
                <span class="temp-readout-label">Hot</span>
                <span class="temp-readout-value" id="temp-readout-hot">50° to 100°</span>
            </div>
        </div>
    </div>
    <ExampleCodeBlock slot="code">
        <CodeSnippet
            lang="html"
            code={`
<rangegroup id="temp-range" min="-100" max="100">
  <label>Cold bound <input type="range" value="-50"></label>
  <label>Mild bound <input type="range" value="0"></label>
  <label>Hot bound <input type="range" value="50"></label>
</rangegroup>

<!-- decorative icons framing the track -->
<svg class="temp-icon-snow"  viewBox="0 0 24 24">...</svg>
<svg class="temp-icon-flame" viewBox="0 0 24 24">...</svg>

<!-- floating zone labels, anchored per segment -->
<div class="temp-zone temp-zone-1">Cold</div>
<div class="temp-zone temp-zone-2">Mild</div>
<div class="temp-zone temp-zone-3">Warm</div>
<div class="temp-zone temp-zone-4">Hot</div>

<div class="temp-readout">
  <div><span>Cold</span><span id="temp-readout-cold">-100° to -50°</span></div>
  <div><span>Mild</span><span id="temp-readout-mild">-50° to 0°</span></div>
  <div><span>Warm</span><span id="temp-readout-warm">0° to 50°</span></div>
  <div><span>Hot</span> <span id="temp-readout-hot">50° to 100°</span></div>
</div>
`}
        />
        <CodeSnippet
            lang="css"
            code={`
/* one colour per zone */
rangegroup::slider-segment(1) { background: #6aa7ff; anchor-name: --temp-seg-1; }
rangegroup::slider-segment(2) { background: #2dd4bf; anchor-name: --temp-seg-2; }
rangegroup::slider-segment(3) { background: #fbbf24; anchor-name: --temp-seg-3; }
rangegroup::slider-segment(4) { background: #fb7185; anchor-name: --temp-seg-4; }

/* each floating label points to its matching segment */
.temp-zone-1 { position-anchor: --temp-seg-1; }
.temp-zone-2 { position-anchor: --temp-seg-2; }
.temp-zone-3 { position-anchor: --temp-seg-3; }
.temp-zone-4 { position-anchor: --temp-seg-4; }
.temp-zone-1,
.temp-zone-2,
.temp-zone-3,
.temp-zone-4 {
  bottom: anchor(top);
  left: anchor(center);
  translate: -50% -10px;
}

/* conic-gradient thumbs that bridge neighbouring zones */
rangegroup::slider-thumb(1) {
  background: conic-gradient(from 180deg, #6aa7ff 0deg 180deg, #2dd4bf 180deg 360deg);
}
rangegroup::slider-thumb(2) {
  background: conic-gradient(from 180deg, #2dd4bf 0deg 180deg, #fbbf24 180deg 360deg);
}
rangegroup::slider-thumb(3) {
  background: conic-gradient(from 180deg, #fbbf24 0deg 180deg, #fb7185 180deg 360deg);
}
`}
        />
        <CodeSnippet
            lang="javascript"
            code={`
const rg     = document.querySelector("#temp-range");
const cells  = {
  cold: document.querySelector("#temp-readout-cold"),
  mild: document.querySelector("#temp-readout-mild"),
  warm: document.querySelector("#temp-readout-warm"),
  hot:  document.querySelector("#temp-readout-hot"),
};
const fmt = v => \`\${Math.round(v)}°\`;

rg.valueTextFormatter = fmt;   /* also formats aria-valuetext */

rg.addEventListener("input", () => {
  const [t1, t2, t3] = rg.values;
  cells.cold.textContent = \`\${fmt(-100)} to \${fmt(t1)}\`;
  cells.mild.textContent = \`\${fmt(t1)} to \${fmt(t2)}\`;
  cells.warm.textContent = \`\${fmt(t2)} to \${fmt(t3)}\`;
  cells.hot.textContent  = \`\${fmt(t3)} to \${fmt(100)}\`;
});
`}
        />
    </ExampleCodeBlock>
    <script is:inline slot="runtime">
        (() => {
            const init = () => {
                const rg     = document.querySelector("#temp-range");
                const cells  = {
                  cold: document.querySelector("#temp-readout-cold"),
                  mild: document.querySelector("#temp-readout-mild"),
                  warm: document.querySelector("#temp-readout-warm"),
                  hot:  document.querySelector("#temp-readout-hot"),
                };
                const fmt = v => `${Math.round(v)}°`;
                
                rg.valueTextFormatter = fmt;   /* also formats aria-valuetext */
                
                rg.addEventListener("input", () => {
                  const [t1, t2, t3] = rg.values;
                  cells.cold.textContent = `${fmt(-100)} to ${fmt(t1)}`;
                  cells.mild.textContent = `${fmt(t1)} to ${fmt(t2)}`;
                  cells.warm.textContent = `${fmt(t2)} to ${fmt(t3)}`;
                  cells.hot.textContent  = `${fmt(t3)} to ${fmt(100)}`;
                });
            };

            const run = () => {
                if (typeof customElements?.whenDefined === "function") {
                    customElements
                        .whenDefined("range-group")
                        .then(init)
                        .catch(() => init());
                    return;
                }
                init();
            };

            if (document.readyState === "loading") {
                document.addEventListener("DOMContentLoaded", run, { once: true });
            } else {
                run();
            }
        })();
    </script>
</ExampleSection>
