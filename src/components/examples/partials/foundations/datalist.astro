---
import ExampleSection from "../../ExampleSection.astro";
import ExampleCodeBlock from "../../ExampleCodeBlock.astro";
import CodeSnippet from "../../CodeSnippet.astro";
---

<ExampleSection id="datalist" eyebrow="Foundations" title="Datalist integration">
    <Fragment slot="description">
        Pair the component with a <code>&lt;datalist&gt;</code> to snap values to discrete options. The component also enforces
        a minimum distance of 25 between handles via
        <code>stepbetween="25"</code>.
    </Fragment>
    <div slot="demo">
        <range-group id="rating-range" min="0" max="100" list="rating-ticks" stepbetween="25">
            <legend slot="legend" class="visually-hidden">Rating range</legend>
            <label class="visually-hidden">
                Minimum rating
                <input type="range" name="rating-min" value="25" />
            </label>
            <label class="visually-hidden">
                Maximum rating
                <input type="range" name="rating-max" value="75" />
            </label>
        </range-group>
        <datalist id="rating-ticks">
            <option value="0" label="0%"></option>
            <option value="25"></option>
            <option value="50" label="50%"></option>
            <option value="75"></option>
            <option value="100" label="100%"></option>
        </datalist>
    </div>
    <ExampleCodeBlock slot="code">
        <CodeSnippet
            lang="html"
            code={`
<rangegroup min="0" max="100" list="rating-ticks" stepbetween="25">
  <label>Minimum rating <input type="range" value="25"></label>
  <label>Maximum rating <input type="range" value="75"></label>
</rangegroup>
<datalist id="rating-ticks">
  <option value="0" label="0%"></option>
  <option value="25"></option>
  <option value="50" label="50%"></option>
  <option value="75"></option>
  <option value="100" label="100%"></option>
</datalist>
`}
        />
    </ExampleCodeBlock>
</ExampleSection>
